# =============================================================================
# verion-ai-grader — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Django core (REQUIRED)
# ---------------------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to True for local development only
DEBUG=False

# Comma-separated list of allowed hostnames (leave empty to use DEBUG default)
# ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------

# PostgreSQL connection string — shared with the main system
DATABASE_URL=postgresql://user:password@localhost:5432/grading_db

# ---------------------------------------------------------------------------
# AWS / Bedrock (REQUIRED)
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Bedrock model identifier
# Example: anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ---------------------------------------------------------------------------
# Grading configuration (OPTIONAL — defaults shown)
# ---------------------------------------------------------------------------

# JSON object mapping letter grades to minimum percentage thresholds
# GRADING_SCALE={"A": 70, "B": 60, "C": 50, "D": 40}

# Maximum tokens per Bedrock invocation
# BEDROCK_MAX_TOKENS=2048

# Number of attempts graded in parallel during batch grading
# GRADING_CONCURRENCY=10
